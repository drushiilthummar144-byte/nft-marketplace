/* Admin Layout & Sidebar Styles */
body {
    display: flex;
    height: 100vh;
    overflow: hidden;
    background-color: #0b0515; /* Maintain the dark theme base */
}

.sidebar {
    width: 280px; /* Fixed width var substitution */
    background: rgba(13, 6, 31, 1);
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    padding: 24px;
}

.nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 8px;
    color: #a1a1aa; /* text-muted */
    font-weight: 500;
    transition: all 0.2s;
    text-decoration: none;
}

.nav-item:hover,
.nav-item.active {
    background: linear-gradient(90deg, rgba(127, 48, 255, 0.1) 0%, rgba(127, 48, 255, 0) 100%);
    color: white;
    border-left: 3px solid #7F30FF; /* primary */
}

.badge-count {
    margin-left: auto;
    background: #7F30FF; /* primary */
    color: white;
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 10px;
}

.main-content {
    flex: 1;
    overflow-y: auto;
    padding: 32px;
}

/* System Header in Sidebar */
.system-header {
    margin-top: 24px; 
    padding-left: 16px; 
    color: rgba(255,255,255,0.4); 
    font-size: 0.75rem; 
    font-weight: 700; 
    letter-spacing: 1px;
    margin-bottom: 8px;
}

/* Specific Admin Components */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 24px;
}

.stat-card {
    padding: 24px;
    border-radius: 16px;
    position: relative;
}

.stat-icon {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
}

.trend-up {
    color: #00C853;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 12px;
}

/* Tables */
.admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
}

.admin-table th {
    text-align: left;
    padding: 16px;
    color: #a1a1aa;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 1px;
}

.admin-table td {
    padding: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    vertical-align: middle;
}

.action-btn {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #a1a1aa;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 0.2s;
    cursor: pointer;
}

.action-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: white;
}

/* Inputs and Forms (matching glass theme) */
.glass-input {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 12px;
    color: white;
    outline: none;
    transition: border-color 0.2s;
}

.glass-input:focus {
    border-color: #7F30FF;
}

.btn-primary {
    background: #7F30FF;
    color: white;
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
}

.btn-primary:hover {
    background: #6a25d6;
}
