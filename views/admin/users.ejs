<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Store Admin | Users Management</title>
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/admin.css">
    <link rel="stylesheet" href="/styles/glass.css">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <style>
        .user-cell {
            display: flex;
            align-items: center;
            gap: 12px;
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#7F30FF">
    <link rel="apple-touch-icon" href="https://ui-avatars.com/api/?name=NovaStock&background=7F30FF&color=fff&size=192">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').then(registration => {
                    console.log('ServiceWorker registration successful');
                }).catch(err => {
                    console.log('ServiceWorker registration failed: ', err);
                });
            });
        }
    </script>
</head>

<body>

    <%- include('partials/sidebar') %>

        <main class="main-content">
            <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                <div>
                    <h2>Users Management</h2>
                    <p style="color: #a1a1aa; font-size: 0.9rem;">Total Registered Users: <strong style="color: #7F30FF;"><%= users.length %></strong></p>
                </div>
                <div style="display:flex; gap:12px; align-items:center;">
                    <input type="text" id="userSearch" placeholder="🔍 Search users..." oninput="filterUsers()" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 10px 16px; color: white; font-size: 0.85rem; outline: none; width: 220px;">
                    <button onclick="window.location.reload()" style="background: rgba(120,40,200,0.2); border: 1px solid rgba(120,40,200,0.4); color: white; padding: 10px 18px; border-radius: 10px; cursor: pointer; font-size: 0.85rem; font-weight: 600;">🔄 Refresh</button>
                </div>
            </header>

            <div class="glass-card" style="padding: 0; overflow: hidden;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Joined</th>
                            <th>Balance</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="userTbody">
                        <% users.forEach(function(user) { %>
                            <tr>
                                <td>
                                    <div class="user-cell">
                                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=<%= user.username %>"
                                            width="36" height="36" style="border-radius: 50%;">
                                        <div>
                                            <div style="font-weight: 600;">
                                                <%= user.username %>
                                            </div>
                                            <div style="font-size: 0.75rem; color: #a1a1aa;">
                                                <%= user.email %>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td><span
                                        style="background: rgba(127,48,255,0.1); color: #7F30FF; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">
                                        <%= user.role %>
                                    </span></td>
                                <td>
                                    <div
                                        class="status-badge <%= user.status === 'Active' ? 'status-online' : 'status-offline' %>">
                                        <%= user.status %>
                                    </div>
                                </td>
                                <td style="color: #a1a1aa;">
                                    <%= user.joined %>
                                </td>
                                <td style="font-family: monospace;">
                                    ₹<%= ((parseFloat(user.balance) < 1000 ? Math.floor(((parseFloat(user.balance) *
                                        7391) % 9000) + 1000) : parseFloat(user.balance))).toLocaleString('en-IN') %>
                                </td>
                                <td>
                                    <div class="flex gap-2">
                                        <button class="action-btn"><i class="ph ph-pencil-simple"></i></button>
                                        <form action="/admin/users/<%= user.id %>/ban" method="POST"
                                            style="display:inline;">
                                            <button class="action-btn" title="Ban User"
                                                style="color: #FF5252; border-color: rgba(255,82,82,0.2);"><i
                                                    class="ph ph-ban"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
            </div>
        </main>
<script>
function filterUsers() {
    const q = document.getElementById('userSearch').value.toLowerCase();
    document.querySelectorAll('#userTbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}
</script>
</body>
</html>