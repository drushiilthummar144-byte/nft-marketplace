<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Store Admin | Settings</title>
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/admin.css">
    <link rel="stylesheet" href="/styles/glass.css">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <style>
        .settings-section {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            color: #a1a1aa;
            font-size: 0.9rem;
        }
    </style>
</head>

<body>

    <%- include('partials/sidebar') %>

        <main class="main-content">
            <h2 style="margin-bottom: 32px;">Platform Settings</h2>

            <form action="/admin/settings" method="POST">
                <div class="settings-section">
                    <h3 style="margin-bottom: 24px;">General Configuration</h3>
                    <div class="grid grid-cols-2 gap-6"
                        style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                        <div class="form-group">
                            <label class="form-label">Platform Name</label>
                            <input type="text" name="siteName" class="glass-input" value="<%= settings.siteName %>">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Support Email</label>
                            <input type="email" name="supportEmail" class="glass-input"
                                value="<%= settings.supportEmail %>">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Maintenance Mode</label>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <input type="checkbox" name="maintenanceMode" <%=settings.maintenanceMode ? 'checked'
                                    : '' %>>
                                <span style="color: #a1a1aa; font-size: 0.9rem;">Enable</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="settings-section">
                    <h3 style="margin-bottom: 24px;">Security</h3>
                    <form action="/admin/password" method="POST">
                        <div class="grid grid-cols-2 gap-6"
                            style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                            <div class="form-group">
                                <label class="form-label">Current Password</label>
                                <input type="password" name="currentPassword" class="glass-input" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">New Password</label>
                                <input type="password" name="newPassword" class="glass-input" required>
                            </div>
                        </div>
                        <div class="flex justify-end">
                            <button type="submit" class="btn btn-secondary">Update Password</button>
                        </div>
                    </form>
                </div>

                <div class="settings-section">
                    <h3 style="margin-bottom: 24px;">Fees & Commission</h3>
                    <div class="grid grid-cols-3 gap-6"
                        style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px;">
                        <div class="form-group">
                            <label class="form-label">Platform Fee (%)</label>
                            <input type="number" step="0.1" name="platformFee" class="glass-input"
                                value="<%= settings.platformFee %>">
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-4">
                    <button type="submit" class="btn btn-primary">Save Configuration</button>
                </div>
            </form>

        </main>
</body>

</html>