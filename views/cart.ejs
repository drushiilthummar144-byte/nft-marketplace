<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Amazon.in Shopping Cart</title>
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/glass.css">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <style>
        body {
            background-color: #eaeded; /* Amazon light gray */
            color: #0f1111;
        }

        .main-header {
            background: #232f3e;
            padding: 12px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header-logo {
            color: white;
            font-size: 1.6rem;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .cart-container {
            max-width: 1200px;
            margin: 20px auto;
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 20px;
            align-items: start;
        }

        @media (max-width: 768px) {
            .cart-container {
                grid-template-columns: 1fr;
            }
        }

        .cart-main {
            background: #ffffff;
            padding: 20px;
            border-radius: 4px;
        }

        .cart-title {
            font-size: 1.8rem;
            font-weight: 400;
            border-bottom: 1px solid #d5d9d9;
            padding-bottom: 10px;
            margin-top: 0;
            margin-bottom: 20px;
        }

        .cart-item {
            display: flex;
            gap: 20px;
            padding: 16px 0;
            border-bottom: 1px solid #d5d9d9;
        }

        .cart-img {
            width: 160px;
            height: 160px;
            object-fit: contain;
            mix-blend-mode: multiply;
        }

        .cart-item-details {
            flex: 1;
        }

        .cart-item-title {
            font-size: 1.1rem;
            color: #007185;
            line-height: 1.4;
            margin-bottom: 4px;
            font-weight: 500;
        }

        .cart-item-price {
            font-size: 1.2rem;
            font-weight: 700;
            color: #0f1111;
            margin-bottom: 8px;
        }

        .stock-status {
            color: #007600;
            font-size: 0.9rem;
            margin-bottom: 8px;
        }

        .btn-remove {
            background: transparent;
            color: #007185;
            border: none;
            cursor: pointer;
            padding: 0;
            font-size: 0.9rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .btn-remove:hover {
            color: #c40000;
            text-decoration: underline;
        }

        .summary-card {
            background: #fff;
            border-radius: 4px;
            padding: 20px;
            position: sticky;
            top: 20px;
        }

        .summary-title {
            font-size: 1.2rem;
            font-weight: 400;
            margin: 0 0 16px 0;
            line-height: 1.2;
        }

        .subtotal {
            font-size: 1.2rem;
            margin-bottom: 16px;
        }
        .subtotal span {
            font-weight: bold;
        }

        .btn-checkout {
            display: block;
            width: 100%;
            background: #ffd814;
            color: #0f1111;
            border: 1px solid #fcd200;
            padding: 10px;
            border-radius: 100px;
            text-decoration: none;
            text-align: center;
            font-size: 0.9rem;
            font-weight: 500;
            box-shadow: 0 2px 5px 0 rgba(213,217,217,.5);
        }

        .btn-checkout:hover {
            background: #f7ca00;
        }
        
        .empty-cart {
            background: white;
            padding: 40px;
            text-align: center;
            border-radius: 4px;
        }
    </style>
</head>

<body>
    <!-- Main EC Navbar -->
    <nav class="main-header">
        <a href="/" class="header-logo">
            <% if (content && content.visuals && content.visuals.logoImage) { %>
                <img src="<%= content.visuals.logoImage %>" alt="Logo" style="height: 36px;">
            <% } else { %>
                <div style="width: 32px; height: 32px; background: #febd69; color: #0f1111; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem;">
                    N</div>
                <span>
                    <%= content && content.visuals && content.visuals.logoText ? content.visuals.logoText : 'NovaMart' %>
                </span>
            <% } %>
        </a>

        <div class="flex items-center gap-4">
            <a href="/explore" style="color: white; text-decoration: none;">Continue Shopping</a>
        </div>
    </nav>

    <div class="cart-container">
        <% if (cart && cart.length > 0) { 
            let total = 0;
        %>
            <div class="cart-main">
                <h1 class="cart-title">Shopping Cart</h1>
                <div style="text-align: right; color: #565959; font-size: 0.9rem; margin-top: -10px; margin-bottom: 10px;">Price</div>
                
                <div class="cart-items">
                    <% cart.forEach(item => { 
                        const price = parseFloat(item.price) < 1000 ? Math.floor(((parseFloat(item.price) * 7391) % 9000) + 1000) : parseFloat(item.price);
                        total += price;
                    %>
                        <div class="cart-item">
                            <img src="<%= item.image %>" class="cart-img" alt="<%= item.title %>">
                            <div class="cart-item-details">
                                <div class="cart-item-title"><%= item.title %></div>
                                <div class="stock-status">In stock</div>
                                <div style="font-size: 0.8rem; color: #565959; margin-bottom: 8px;">Brand: <%= item.brand %></div>
                                
                                <form action="/cart/remove" method="POST" style="margin: 0; display: inline;">
                                    <input type="hidden" name="productId" value="<%= item.id %>">
                                    <button type="submit" class="btn-remove">
                                        Delete
                                    </button>
                                </form>
                            </div>
                            <div class="cart-item-price">₹<%= price.toLocaleString('en-IN') %></div>
                        </div>
                    <% }); %>
                </div>
                
                <div style="text-align: right; margin-top: 16px; font-size: 1.2rem;">
                    Subtotal (<%= cart.length %> items): <strong>₹<%= total.toLocaleString('en-IN') %></strong>
                </div>
            </div>

            <div class="summary-card">
                <div class="subtotal">
                    Subtotal (<%= cart.length %> items): <br><span>₹<%= total.toLocaleString('en-IN') %></span>
                </div>
                <div style="font-size: 0.9rem; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                    <i class="ph-fill ph-check-circle" style="color: #067d62; font-size: 1.2rem;"></i>
                    <span style="color: #067d62;">Your order is eligible for FREE Delivery.</span>
                </div>
                
                <a href="<%= user ? '/checkout?id=cart' : '/login' %>" class="btn-checkout">
                    Proceed to Buy
                </a>
            </div>
        <% } else { %>
            <div style="grid-column: 1 / -1;" class="empty-cart">
                <i class="ph ph-shopping-cart" style="font-size: 5rem; color: #d5d9d9; margin-bottom: 16px;"></i>
                <h2 style="font-size: 1.5rem; margin-bottom: 12px; font-weight: 500;">Your Amazon Cart is empty.</h2>
                <p style="color: #565959; margin-bottom: 24px;">Check your Saved for later items below or continue shopping.</p>
                <a href="/explore" style="display: inline-block; padding: 10px 20px; background: #ffd814; border: 1px solid #fcd200; border-radius: 8px; color: #0f1111; text-decoration: none; font-weight: 500;">Continue shopping</a>
            </div>
        <% } %>
    </div>
<script src="/js/quicknav.js"></script>
</body>
</html>
