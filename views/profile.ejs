<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NFT Marketplace | Profile</title>
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/glass.css">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <style>
        .banner {
            height: 250px;
            background: linear-gradient(45deg, #2A1A40, #1A1A2E);
            position: relative;
        }

        .profile-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 4px solid #0b0515;
            position: absolute;
            bottom: -60px;
            left: 40px;
            background: #333;
        }

        .profile-nav {
            margin-top: 80px;
            padding: 0 40px;
            display: flex;
            gap: 32px;
            border-bottom: 1px solid var(--border-light);
        }

        .profile-nav-item {
            padding-bottom: 16px;
            cursor: pointer;
            color: var(--text-muted);
            font-weight: 500;
        }

        .profile-nav-item.active {
            color: white;
            border-bottom: 2px solid var(--primary);
        }
    </style>
</head>

<body>

    <nav class="glass-nav"
        style="position: sticky; top: 0; z-index: 100; padding: 20px 0; border-bottom: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(20px); background: rgba(11, 5, 21, 0.8);">
        <div class="container flex justify-between items-center">
            <div class="flex items-center gap-2">
                <div
                    style="width: 40px; height: 40px; background: var(--primary); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem;">
                    N</div>
                <a href="/" style="font-size: 1.2rem; font-weight: 700; color: white; text-decoration: none;">NFT
                    Nexus</a>
            </div>
            <div class="hidden md:flex gap-8">
                <a href="/" class="nav-link" style="color: var(--text-muted); text-decoration: none;">Home</a>
                <a href="/explore" class="nav-link" style="color: var(--text-muted); text-decoration: none;">Explore</a>
            </div>
            <div class="flex items-center gap-4">
                <div
                    style="display: flex; align-items: center; gap: 8px; background: rgba(0, 255, 157, 0.1); border: 1px solid rgba(0, 255, 157, 0.3); padding: 8px 16px; border-radius: 20px;">
                    <i class="ph-fill ph-check-circle" style="color: #00ff9d;"></i>
                    <span style="font-weight: 600; color: #00ff9d; font-size: 0.9rem;">Wallet Connected</span>
                </div>
                <div
                    style="padding: 8px 16px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 20px; font-weight: 600; display: flex; align-items: center; gap: 6px;">
                    <i class="ph-bold ph-currency-eth" style="color: var(--primary);"></i> 12.5 ETH
                </div>
                <div style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--primary), #FF3085); border: 2px solid white; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.2s;"
                    onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                    <img src="<%= user.avatar || 'https://api.dicebear.com/7.x/avataaars/svg?seed=' + user.username %>"
                        style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                </div>
            </div>
        </div>
    </nav>

    <!-- Dynamic Banner -->
    <style>
        .banner {
            background: linear-gradient(45deg, #2A1A40, #1A1A2E);
            background-size: cover;
            background-position: center;
        }
    </style>
    <div class="banner" style="<%= user.banner ? 'background-image: url(' + user.banner + ');' : '' %>">
        <img class="profile-avatar"
            src="<%= user.avatar || 'https://api.dicebear.com/7.x/avataaars/svg?seed=' + user.username %>" alt="Avatar">
    </div>

    <div class="container">
        <div
            style="margin-top: 70px; padding-left: 20px; display: flex; justify-content: space-between; align-items: flex-end;">
            <div>
                <h1 style="font-size: 2.5rem; margin-bottom: 8px;">
                    <%= user.username %> <i class="ph-fill ph-seal-check text-primary"
                            style="font-size: 1.5rem; color: #3085FF;"></i>
                </h1>
                <div style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 12px;">@<%=
                        user.username.toLowerCase() %> • Joined <%= user.joined || '2024' %>
                </div>
                <% if(user.bio) { %>
                    <p style="max-width: 600px; line-height: 1.6; color: rgba(255,255,255,0.8);">
                        <%= user.bio %>
                    </p>
                    <% } %>
                        <% if(user.website || user.twitter || user.instagram) { %>
                            <div class="flex gap-4 mt-4 text-muted">
                                <% if(user.website) { %> <a href="<%= user.website %>" target="_blank"
                                        class="hover:text-white"><i class="ph ph-globe"></i> Website</a>
                                    <% } %>
                                        <% if(user.twitter) { %> <a href="#" class="hover:text-white"><i
                                                    class="ph ph-twitter-logo"></i> @<%= user.twitter %></a>
                                            <% } %>
                                                <% if(user.instagram) { %> <a href="#" class="hover:text-white"><i
                                                            class="ph ph-instagram-logo"></i> @<%= user.instagram %>
                                                    </a>
                                                    <% } %>
                            </div>
                            <% } %>
            </div>
            <div class="flex gap-4">
                <button onclick="openModal('createModal')" class="btn"
                    style="background: linear-gradient(135deg, #7828C8, #FF3085); color: white; border-radius: 12px; font-weight: 700; border: none; box-shadow: 0 5px 15px rgba(127,48,255,0.4); display: flex; align-items: center; gap: 8px;">
                    <i class="ph-bold ph-plus"></i> Mint New NFT
                </button>
                <% if (locals.user && locals.user.id===user.id) { %>
                    <button onclick="openModal('editModal')" class="btn btn-secondary"
                        style="border-radius: 12px; display: flex; align-items: center; gap: 6px;">
                        <i class="ph ph-pencil-simple"></i> Edit Profile
                    </button>
                    <button onclick="openModal('securityModal')" class="btn btn-secondary"
                        style="border-radius: 12px; display: flex; align-items: center; gap: 6px;">
                        <i class="ph ph-shield-check"></i> Security
                    </button>
                    <a href="/logout" class="btn"
                        style="background: rgba(255,50,50,0.1); color: #ff4d4d; border: 1px solid rgba(255,50,50,0.3); border-radius: 12px; display: flex; align-items: center; gap: 6px; text-decoration: none;">
                        <i class="ph ph-sign-out"></i> Logout
                    </a>
                    <% } %>
            </div>
        </div>

        <div class="profile-nav">
            <div class="profile-nav-item active" onclick="switchTab('created', this)">Created <span
                    style="background: rgba(255,255,255,0.1); padding: 2px 8px; border-radius: 10px; font-size: 0.8rem; margin-left: 4px;">
                    <%= createdItems.length %>
                </span></div>
            <div class="profile-nav-item" onclick="switchTab('collected', this)">Collected <span
                    style="background: rgba(255,255,255,0.1); padding: 2px 8px; border-radius: 10px; font-size: 0.8rem; margin-left: 4px;">
                    <%= collectedItems.length %>
                </span></div>
            <div class="profile-nav-item" onclick="switchTab('favorited', this)">Favorited <span
                    style="background: rgba(255,255,255,0.1); padding: 2px 8px; border-radius: 10px; font-size: 0.8rem; margin-left: 4px;">
                    <%= favoritedItems.length %>
                </span></div>
            <div class="profile-nav-item" onclick="switchTab('orders', this)">My Orders <span
                    style="background: rgba(255,255,255,0.1); padding: 2px 8px; border-radius: 10px; font-size: 0.8rem; margin-left: 4px;">
                    <%= typeof myOrders !=='undefined' ? myOrders.length : 0 %>
                </span></div>
            <div class="profile-nav-item" onclick="switchTab('sales', this)">My Sales (Incoming) <span
                    style="background: rgba(0,255,157,0.1); color: #00ff9d; padding: 2px 8px; border-radius: 10px; font-size: 0.8rem; margin-left: 4px;">
                    <%= typeof mySales !=='undefined' ? mySales.length : 0 %>
                </span></div>
        </div>

        <!-- CONTENT SECTIONS -->
        <div id="content-container" style="padding: 40px 0;">

            <!-- CREATED SECTION -->
            <div id="tab-created" class="tab-content"
                style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 32px;">
                <% if(createdItems && createdItems.length> 0) { %>
                    <% createdItems.forEach(item=> { %>
                        <div class="glass-card" style="padding: 16px; transition: transform 0.2s;"
                            onmouseover="this.style.transform='translateY(-5px)'"
                            onmouseout="this.style.transform='translateY(0)'">
                            <div
                                style="height: 240px; background-image: url('<%= item.image %>'); background-size: cover; border-radius: 12px; margin-bottom: 16px; position: relative;">
                            </div>
                            <div style="font-weight: 700; font-size: 1.2rem; margin-bottom: 4px;">
                                <%= item.title %>
                            </div>
                            <div style="font-size: 0.9rem; color: var(--text-muted);">Price: <%= item.price %> ETH
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div style="grid-column: 1/-1; text-align: center; padding: 60px;">
                                    <i class="ph ph-pencil-simple-slash"
                                        style="font-size: 3rem; color: var(--text-muted); margin-bottom: 16px;"></i>
                                    <h3 style="color: var(--text-muted);">No items created yet</h3>
                                    <p style="color: var(--text-muted); opacity: 0.7;">Create your first NFT to see
                                        it
                                        here!</p>
                                </div>
                                <% } %>
            </div>

            <!-- COLLECTED SECTION -->
            <div id="tab-collected" class="tab-content"
                style="display: none; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 32px;">
                <% if(collectedItems && collectedItems.length> 0) { %>
                    <% collectedItems.forEach(item=> { %>
                        <div class="glass-card" style="padding: 16px;">
                            <div
                                style="height: 240px; background-image: url('<%= item.image %>'); background-size: cover; border-radius: 12px; margin-bottom: 16px;">
                            </div>
                            <div style="font-weight: 700; font-size: 1.2rem;">
                                <%= item.title %>
                            </div>
                            <div style="font-size: 0.9rem; color: var(--text-muted);">Owned by You</div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div style="grid-column: 1/-1; text-align: center; padding: 60px;">
                                    <i class="ph ph-shopping-bag-open"
                                        style="font-size: 3rem; color: var(--text-muted); margin-bottom: 16px;"></i>
                                    <h3 style="color: var(--text-muted);">No items collected yet</h3>
                                    <button class="btn btn-primary" style="margin-top: 20px;"
                                        onclick="window.location.href='/explore'">Explore Marketplace</button>
                                </div>
                                <% } %>
            </div>

            <!-- FAVORITED SECTION -->
            <div id="tab-favorited" class="tab-content"
                style="display: none; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 32px;">
                <% if(favoritedItems && favoritedItems.length> 0) { %>
                    <% favoritedItems.forEach(item=> { %>
                        <div class="glass-card" style="padding: 16px;">
                            <div
                                style="height: 240px; background-image: url('<%= item.image %>'); background-size: cover; border-radius: 12px; margin-bottom: 16px; position: relative;">
                                <div
                                    style="position: absolute; top: 10px; right: 10px; background: rgba(255,50,50,0.2); backdrop-filter: blur(4px); padding: 8px; border-radius: 50%; color: #ff4d4d;">
                                    <i class="ph-fill ph-heart"></i>
                                </div>
                            </div>
                            <div style="font-weight: 700; font-size: 1.2rem;">
                                <%= item.title %>
                            </div>
                            <div style="font-size: 0.9rem; color: var(--text-muted);">Price: <%= item.price %> ETH
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div style="grid-column: 1/-1; text-align: center; padding: 60px;">
                                    <i class="ph ph-heart-break"
                                        style="font-size: 3rem; color: var(--text-muted); margin-bottom: 16px;"></i>
                                    <h3 style="color: var(--text-muted);">No favorites yet</h3>
                                    <p style="color: var(--text-muted); opacity: 0.7;">Browse and like items to save
                                        them here.</p>
                                </div>
                                <% } %>
            </div>

            <!-- MY ORDERS SECTION (What I Bought) -->
            <div id="tab-orders" class="tab-content" style="display: none; padding: 20px 0;">
                <h3 style="margin-bottom: 24px;">Items I Ordered</h3>
                <% if(typeof myOrders !=='undefined' && myOrders.length> 0) { %>
                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        <% myOrders.forEach(order=> { %>
                            <div class="glass-card flex justify-between items-center" style="padding: 16px;">
                                <div class="flex items-center gap-4">
                                    <img src="<%= order.image %>"
                                        style="width: 80px; height: 80px; border-radius: 12px; object-fit: cover;">
                                    <div>
                                        <div style="font-weight: 700; font-size: 1.1rem;">
                                            <%= order.title %>
                                        </div>
                                        <div style="color: var(--text-muted); font-size: 0.9rem;">From: <%= order.seller
                                                %> | Price: <%= order.price %> ETH</div>
                                        <div style="margin-top: 4px; font-size: 0.85rem;">
                                            Status: <span
                                                style="color: <%= order.status === 'Accepted' ? '#00ff9d' : (order.status === 'Cancelled' ? '#ff4d4d' : '#ffb800') %>; font-weight: 600;">
                                                <%= order.status %>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div>
                                    <% if(order.status==='Pending' ) { %>
                                        <form action="/order/cancel" method="POST" style="display: inline;">
                                            <input type="hidden" name="orderId" value="<%= order.id %>">
                                            <button type="submit" class="btn btn-secondary"
                                                style="border-color: rgba(255,77,77,0.3); color: #ff4d4d;"
                                                onclick="return confirm('Are you sure you want to cancel this order?')">Cancel
                                                Order</button>
                                        </form>
                                        <% } %>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <div
                            style="text-align: center; padding: 60px; background: rgba(255,255,255,0.02); border-radius: 16px;">
                            <i class="ph ph-package"
                                style="font-size: 3rem; color: var(--text-muted); margin-bottom: 16px;"></i>
                            <h3 style="color: var(--text-muted);">No orders found</h3>
                        </div>
                        <% } %>
            </div>

            <!-- MY SALES SECTION (Incoming Orders) -->
            <div id="tab-sales" class="tab-content" style="display: none; padding: 20px 0;">
                <h3 style="margin-bottom: 24px;">Incoming Orders (My Sales)</h3>
                <% if(typeof mySales !=='undefined' && mySales.length> 0) { %>
                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        <% mySales.forEach(order=> { %>
                            <div class="glass-card flex justify-between items-center"
                                style="padding: 16px; border: <%= order.status === 'Pending' ? '1px solid rgba(0,255,157,0.3)' : '1px solid rgba(255,255,255,0.1)' %>">
                                <div class="flex items-center gap-4">
                                    <img src="<%= order.image %>"
                                        style="width: 80px; height: 80px; border-radius: 12px; object-fit: cover;">
                                    <div>
                                        <div style="font-weight: 700; font-size: 1.1rem;">
                                            <%= order.title %>
                                        </div>
                                        <div style="color: var(--text-muted); font-size: 0.9rem;">Buyer: <%= order.buyer
                                                %> | Amount: <%= order.price %> ETH</div>
                                        <div style="margin-top: 4px; font-size: 0.85rem;">
                                            Status: <span
                                                style="color: <%= order.status === 'Accepted' ? '#00ff9d' : (order.status === 'Cancelled' ? '#ff4d4d' : '#ffb800') %>; font-weight: 600;">
                                                <%= order.status %>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex gap-2">
                                    <% if(order.status==='Pending' ) { %>
                                        <form action="/order/accept" method="POST" style="display: inline;">
                                            <input type="hidden" name="orderId" value="<%= order.id %>">
                                            <button type="submit" class="btn"
                                                style="background: rgba(0,255,157,0.1); border: 1px solid #00ff9d; color: #00ff9d;">Accept
                                                Order</button>
                                        </form>
                                        <form action="/order/cancel" method="POST" style="display: inline;">
                                            <input type="hidden" name="orderId" value="<%= order.id %>">
                                            <button type="submit" class="btn btn-secondary"
                                                style="border-color: rgba(255,77,77,0.3); color: #ff4d4d;"
                                                onclick="return confirm('Reject this order?')">Reject</button>
                                        </form>
                                        <% } else if(order.status==='Accepted' ) { %>
                                            <div
                                                style="background: rgba(0,255,157,0.1); color: #00ff9d; padding: 6px 16px; border-radius: 8px; font-size: 0.9rem;">
                                                <i class="ph-bold ph-check"></i> Sold
                                            </div>
                                            <% } %>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <div
                            style="text-align: center; padding: 60px; background: rgba(255,255,255,0.02); border-radius: 16px;">
                            <i class="ph ph-bell-slash"
                                style="font-size: 3rem; color: var(--text-muted); margin-bottom: 16px;"></i>
                            <h3 style="color: var(--text-muted);">No sales yet</h3>
                        </div>
                        <% } %>
            </div>

        </div>
    </div>

    <!-- Edit Profile Modal -->
    <div id="editModal" class="modal-overlay"
        style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); z-index: 200; align-items: center; justify-content: center;">
        <div class="glass-card"
            style="width: 100%; max-width: 600px; padding: 32px; max-height: 90vh; overflow-y: auto;">
            <div class="flex justify-between items-center mb-6">
                <h3 style="font-size: 1.5rem;">Edit Profile</h3>
                <button onclick="closeModal('editModal')"
                    style="background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer;"><i
                        class="ph ph-x"></i></button>
            </div>
            <form action="/profile/edit" method="POST">
                <div class="grid md:grid-cols-2 gap-4"
                    style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">Display
                            Name</label>
                        <input type="text" name="username" class="glass-input" value="<%= user.username %>" required>
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">Website</label>
                        <input type="text" name="website" class="glass-input" placeholder="https://yoursite.com"
                            value="<%= user.website || '' %>">
                    </div>
                </div>

                <div style="margin-top: 20px; margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">Bio</label>
                    <textarea name="bio" class="glass-input" rows="3"
                        placeholder="Tell the world about yourself..."><%= user.bio || '' %></textarea>
                </div>

                <div class="grid md:grid-cols-2 gap-4"
                    style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px;">
                    <div>
                        <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">Twitter
                            Username</label>
                        <div class="relative">
                            <div style="position: absolute; left: 12px; top: 12px; color: var(--text-muted);">@
                            </div>
                            <input type="text" name="twitter" class="glass-input" style="padding-left: 32px;"
                                value="<%= user.twitter || '' %>">
                        </div>
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">Instagram
                            Username</label>
                        <div class="relative">
                            <div style="position: absolute; left: 12px; top: 12px; color: var(--text-muted);">@
                            </div>
                            <input type="text" name="instagram" class="glass-input" style="padding-left: 32px;"
                                value="<%= user.instagram || '' %>">
                        </div>
                    </div>
                </div>

                <div style="margin-bottom: 24px;">
                    <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">Avatar URL</label>
                    <input type="text" name="avatarUrl" class="glass-input" placeholder="https://api.dicebear.com/..."
                        value="<%= user.avatar || '' %>">
                </div>

                <div style="margin-bottom: 32px;">
                    <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">Banner Image
                        URL</label>
                    <input type="text" name="bannerUrl" class="glass-input" placeholder="https://picsum.photos/..."
                        value="<%= user.banner || '' %>">
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">Save
                    Profile</button>
            </form>
        </div>
    </div>

    <!-- Create NFT Modal -->
    <div id="createModal" class="modal-overlay"
        style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); z-index: 200; align-items: center; justify-content: center;">
        <div class="glass-card"
            style="width: 100%; max-width: 900px; padding: 0; display: flex; overflow: hidden; border: 1px solid rgba(127, 48, 255, 0.4); box-shadow: 0 0 40px rgba(127, 48, 255, 0.3);">

            <!-- Left Side: Visual Preview -->
            <div
                style="flex: 1; background: #0D061F; padding: 40px; display: flex; flex-direction: column; justify-content: center; align-items: center; border-right: 1px solid rgba(255,255,255,0.05);">
                <div style="width: 100%; height: 300px; border-radius: 16px; border: 2px dashed rgba(255,255,255,0.2); display: flex; justify-content: center; align-items: center; overflow: hidden; position: relative;"
                    id="imagePreviewContainer">
                    <i class="ph ph-image text-muted" style="font-size: 4rem; position: absolute; z-index: 1;"
                        id="imagePreviewIcon"></i>
                    <img src="" id="imagePreview"
                        style="width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.3s; position: absolute; z-index: 2;">
                </div>
                <div style="margin-top: 24px; text-align: center;">
                    <h4 style="margin-bottom: 8px;">Live Preview</h4>
                    <p class="text-sm text-muted">Enter an image URL on the right to see it here.</p>
                </div>
            </div>

            <!-- Right Side: Details Form -->
            <div style="flex: 1; padding: 40px;">
                <div class="flex justify-between items-center mb-6">
                    <h3
                        style="font-size: 1.8rem; font-weight: 800; background: linear-gradient(135deg, #fff, var(--primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                        Mint an NFT</h3>
                    <button onclick="closeModal('createModal')"
                        style="background: rgba(255,255,255,0.1); border: none; color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.2s;"><i
                            class="ph ph-x"></i></button>
                </div>
                <form action="/nft/create" method="POST">
                    <div style="margin-bottom: 20px;">
                        <label
                            style="display: block; margin-bottom: 8px; color: var(--text-muted); font-weight: 600;">Artwork
                            Title</label>
                        <input type="text" name="title" class="glass-input" placeholder="e.g. Cyber Punk #007" required
                            style="font-size: 1.1rem; height: 50px;">
                    </div>
                    <div style="margin-bottom: 20px;">
                        <label
                            style="display: block; margin-bottom: 8px; color: var(--text-muted); font-weight: 600;">Price
                            in ETH</label>
                        <div class="relative">
                            <i class="ph ph-currency-eth absolute"
                                style="left: 16px; top: 16px; color: var(--text-muted);"></i>
                            <input type="number" step="0.01" name="price" class="glass-input" placeholder="0.5" required
                                style="padding-left: 48px; font-size: 1.1rem; height: 50px;">
                        </div>
                    </div>
                    <div style="margin-bottom: 32px;">
                        <label
                            style="display: block; margin-bottom: 8px; color: var(--text-muted); font-weight: 600;">Image
                            Source URL</label>
                        <input type="url" name="imageUrl" id="imageUrlInput" class="glass-input"
                            placeholder="https://picsum.photos/..." required style="font-size: 1rem; height: 50px;">
                    </div>
                    <button type="submit" class="btn btn-primary"
                        style="width: 100%; justify-content: center; height: 56px; font-size: 1.1rem; border-radius: 12px; box-shadow: 0 10px 20px rgba(127, 48, 255, 0.4);">
                        Mint to Blockchain
                    </button>
                </form>
            </div>
            <script>
                document.getElementById('imageUrlInput').addEventListener('input', function (e) {
                    const preview = document.getElementById('imagePreview');
                    const icon = document.getElementById('imagePreviewIcon');
                    if (e.target.value) {
                        preview.src = e.target.value;
                        preview.onload = () => { preview.style.opacity = '1'; icon.style.opacity = '0'; };
                        preview.onerror = () => { preview.style.opacity = '0'; icon.style.opacity = '1'; };
                    } else {
                        preview.style.opacity = '0';
                        icon.style.opacity = '1';
                    }
                });
            </script>
        </div>
    </div>

    <!-- Security Modal -->
    <div id="securityModal" class="modal-overlay"
        style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); z-index: 200; align-items: center; justify-content: center;">
        <div class="glass-card"
            style="width: 100%; max-width: 500px; padding: 32px; border: 1px solid rgba(127, 48, 255, 0.3); box-shadow: 0 0 30px rgba(127, 48, 255, 0.2);">
            <div class="flex justify-between items-center mb-6">
                <h3 style="font-size: 1.5rem;">Change Password</h3>
                <button onclick="closeModal('securityModal')"
                    style="background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer;"><i
                        class="ph ph-x"></i></button>
            </div>
            <form action="/profile/password" method="POST">
                <div style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">Current
                        Password</label>
                    <input type="password" name="currentPassword" class="glass-input" required>
                </div>
                <div style="margin-bottom: 24px;">
                    <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">New
                        Password</label>
                    <input type="password" name="newPassword" class="glass-input" required>
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">Update
                    Password</button>
            </form>
        </div>
    </div>

    <script>
        function openModal(id) {
            const modal = document.getElementById(id);
            modal.style.display = 'flex';
            // Add slight animation
            modal.querySelector('.glass-card').style.animation = 'scaleIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
        }

        function closeModal(id) {
            document.getElementById(id).style.display = 'none';
        }

        function switchTab(tabName, element) {
            // 1. Hide all tab contents
            document.querySelectorAll('.tab-content').forEach(el => {
                el.style.display = 'none';
            });
            // 2. Show active tab content
            const activeContent = document.getElementById('tab-' + tabName);
            if (activeContent) {
                activeContent.style.display = 'grid'; // Maintain grid layout
            }

            // 3. Update nav items
            document.querySelectorAll('.profile-nav-item').forEach(el => {
                el.classList.remove('active');
            });
            element.classList.add('active');
        }
    </script>

    <style>
        @keyframes scaleIn {
            from {
                transform: scale(0.9);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }
    </style>

    <% if (typeof status !=='undefined' && status==='ordered' ) { %>
        <div id="successOverlay"
            style="position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(10px); z-index: 9999; display: flex; align-items: center; justify-content: center; animation: fadeIn 0.3s ease-out;">
            <div
                style="background: linear-gradient(135deg, rgba(0, 255, 157, 0.1), rgba(11, 5, 21, 0.9)); border: 1px solid rgba(0, 255, 157, 0.4); padding: 50px; border-radius: 30px; text-align: center; box-shadow: 0 20px 50px rgba(0, 255, 157, 0.2); animation: scaleInOverlay 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);">
                <div
                    style="width: 100px; height: 100px; background: rgba(0, 255, 157, 0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; border: 2px solid #00ff9d; box-shadow: 0 0 30px rgba(0, 255, 157, 0.4);">
                    <i class="ph-bold ph-check" style="font-size: 3rem; color: #00ff9d;"></i>
                </div>
                <h1 style="font-size: 2.5rem; color: white; margin-bottom: 8px;">Order Confirmed!</h1>
                <p
                    style="color: rgba(255,255,255,0.7); font-size: 1.1rem; margin-bottom: 32px; max-width: 350px; margin-left: auto; margin-right: auto;">
                    Your transaction was successful. The seller has been notified of your purchase.
                </p>
                <div style="display: flex; gap: 16px; justify-content: center;">
                    <button
                        onclick="document.getElementById('successOverlay').style.display='none'; switchTab('orders', document.querySelector('.profile-nav-item:nth-child(4)'));"
                        class="btn"
                        style="background: #00ff9d; color: #0b0515; font-weight: 800; padding: 12px 24px; border-radius: 12px; font-size: 1rem;">
                        View My Orders
                    </button>
                    <button onclick="document.getElementById('successOverlay').style.display='none'"
                        class="btn btn-secondary" style="border-radius: 12px; font-size: 1rem;">
                        Close
                    </button>
                </div>
            </div>
        </div>
        <style>
            @keyframes scaleInOverlay {
                from {
                    transform: scale(0.8);
                    opacity: 0;
                }

                to {
                    transform: scale(1);
                    opacity: 1;
                }
            }
        </style>
        <script>
            // Automatically close after 6 seconds
            setTimeout(() => {
                const overlay = document.getElementById('successOverlay');
                if (overlay) overlay.style.display = 'none';
            }, 6000);

            // Auto open orders tab
            setTimeout(() => {
                const ordersNav = document.querySelector('.profile-nav-item:nth-child(4)'); // 4th item is orders
                if (ordersNav) switchTab('orders', ordersNav);
            }, 100);
        </script>
        <% } %>

</body>

</html>