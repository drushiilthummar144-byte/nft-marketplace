<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SamKart | <%= product.title %>
    </title>
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/glass.css">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#7F30FF">
    <link rel="apple-touch-icon" href="https://ui-avatars.com/api/?name=SamKart&background=7F30FF&color=fff&size=192">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js');
            });
        }
    </script>

    <style>
        body {
            background-color: var(--bg-dark);
            color: white;
            margin: 0;
            padding: 0;
        }

        .product-page-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 24px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }

        @media (max-width: 900px) {
            .product-page-container {
                grid-template-columns: 1fr;
            }
        }

        .img-showcase {
            background: #fff;
            border-radius: 16px;
            padding: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        .img-showcase img {
            max-width: 100%;
            height: auto;
            object-fit: contain;
            max-height: 500px;
            filter: drop-shadow(0 20px 30px rgba(0, 0, 0, 0.2));
            transition: transform 0.3s;
        }

        .img-showcase img:hover {
            transform: scale(1.05);
        }

        .discount-badge-lg {
            position: absolute;
            top: 20px;
            left: 20px;
            background: #FF3085;
            color: white;
            padding: 8px 16px;
            border-radius: 8px;
            font-weight: 800;
            font-size: 1.1rem;
            z-index: 10;
        }

        .product-info-panel {
            display: flex;
            flex-direction: column;
        }

        .brand-link {
            color: var(--primary);
            text-decoration: none;
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 8px;
            display: inline-block;
        }

        .brand-link:hover {
            text-decoration: underline;
        }

        .product-title {
            font-size: 2.5rem;
            line-height: 1.2;
            margin: 0 0 16px 0;
            font-weight: 800;
        }

        .rating-stars {
            color: #FFB800;
            font-size: 1.2rem;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .price-box {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 32px;
        }

        .main-price {
            font-size: 3rem;
            font-weight: 800;
            color: #fff;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .mrp-price {
            font-size: 1.2rem;
            color: var(--text-muted);
            text-decoration: line-through;
            font-weight: normal;
        }

        .taxes-inclusive {
            color: #00ff9d;
            font-size: 0.9rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-buy-lg {
            background: #FFB800;
            color: #000;
            font-size: 1.2rem;
            font-weight: 800;
            padding: 16px;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            text-decoration: none;
            transition: all 0.2s;
            margin-bottom: 16px;
        }

        .btn-buy-lg:hover {
            background: #ffcc33;
            transform: translateY(-2px);
        }

        .btn-cart-lg {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            font-size: 1.2rem;
            font-weight: 600;
            padding: 16px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            cursor: pointer;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            transition: all 0.2s;
        }

        .btn-cart-lg:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .features-list {
            margin: 0;
            padding: 0;
            list-style: none;
            margin-bottom: 32px;
        }

        .features-list li {
            margin-bottom: 12px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            color: #ddd;
            font-size: 1.05rem;
            line-height: 1.5;
        }

        .features-list i {
            color: var(--primary);
            font-size: 1.4rem;
            margin-top: 2px;
        }

        .secure-box-wrapper {
            display: flex;
            gap: 20px;
            margin-bottom: 32px;
        }

        .secure-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 8px;
            font-size: 0.85rem;
            color: var(--text-muted);
            flex: 1;
        }

        .secure-item i {
            font-size: 2rem;
            color: #a1a1aa;
        }

        .nav-link {
            margin-left: 15px;
            color: #fff;
            text-decoration: none;
        }

        .nav-link:hover {
            color: var(--primary);
        }
    </style>
</head>

<body>

    <!-- Main Navigation -->
    <nav
        style="position: sticky; top: 0; z-index: 100; padding: 16px 24px; border-bottom: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(20px); background: rgba(11, 5, 21, 0.85); display: flex; align-items: center; justify-content: space-between; gap: 24px;">
        <div class="flex items-center gap-2">
            <div
                style="width: 36px; height: 36px; background: var(--primary); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem;">
                N</div>
            <a href="/" style="font-size: 1.4rem; font-weight: 800; color: white; text-decoration: none;">SamKart</a>
        </div>

        <div class="hidden md:flex items-center gap-6">
            <a href="/" class="nav-link">Home</a>
            <a href="/explore" class="nav-link">Explore</a>
        </div>

        <div class="flex items-center gap-4">
            <% if (user) { %>
                <a href="/profile"
                    style="color: white; text-decoration: none; display: flex; flex-direction: column; align-items: center; font-size: 0.8rem;">
                    <i class="ph ph-user" style="font-size: 1.4rem; margin-bottom: 2px;"></i> Profile
                </a>
                <a href="/cart"
                    style="color: white; text-decoration: none; display: flex; flex-direction: column; align-items: center; font-size: 0.8rem; position: relative;">
                    <i class="ph ph-shopping-cart" style="font-size: 1.4rem; margin-bottom: 2px;"></i> Cart
                    <span
                        style="position: absolute; top: -5px; right: -5px; background: #FF3085; color: white; font-size: 10px; width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: bold;">0</span>
                </a>
                <a href="/logout"
                    style="color: #ff4d4d; text-decoration: none; display: flex; flex-direction: column; align-items: center; font-size: 0.8rem;">
                    <i class="ph ph-sign-out" style="font-size: 1.4rem; margin-bottom: 2px;"></i> Exit
                </a>
                <% } else { %>
                    <a href="/login" class="btn btn-primary" style="padding: 10px 24px; border-radius: 8px;">Login</a>
                    <% } %>
        </div>
    </nav>

    <div class="product-page-container">
        <!-- Left: Image Box -->
        <div class="img-showcase">
            <div class="discount-badge-lg">-<%= Math.floor(Math.random() * 30 + 10) %>% OFF</div>
            <img src="<%= product.image %>" alt="<%= product.title %>">
        </div>

        <!-- Right: Details Box -->
        <div class="product-info-panel">
            <a href="/explore?search=<%= product.brand %>" class="brand-link">Visit the <%= product.brand %> Store</a>
            <h1 class="product-title">
                <%= product.title %>
            </h1>

            <div class="rating-stars">
                <i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i
                    class="ph-fill ph-star"></i><i class="ph-fill ph-star-half"></i>
                <span style="color: var(--primary); font-size: 1rem; margin-left: 8px; cursor: pointer;">
                    <%= Math.floor(Math.random() * 5000 + 100) %> ratings | <%= Math.floor(Math.random() * 500 + 10) %>
                            answered questions
                </span>
            </div>

            <div style="border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 24px;"></div>

            <div class="price-box">
                <div class="main-price">
                    ₹<%= ((parseFloat(product.price) < 1000 ? Math.floor(((parseFloat(product.price) * 7391) % 9000) +
                        1000) : parseFloat(product.price))).toLocaleString('en-IN') %>
                        <span class="mrp-price">M.R.P: ₹<%= (parseFloat(product.price) * 1.4).toLocaleString('en-IN') %>
                                </span>
                </div>
                <div class="taxes-inclusive">
                    <i class="ph-fill ph-check-circle"></i> Inclusive of all taxes
                </div>
            </div>

            <div class="secure-box-wrapper">
                <div class="secure-item">
                    <i class="ph ph-truck"></i>
                    <span>Free Delivery</span>
                </div>
                <div class="secure-item">
                    <i class="ph ph-arrows-counter-clockwise"></i>
                    <span>7 Days Replacement</span>
                </div>
                <div class="secure-item">
                    <i class="ph ph-shield-check"></i>
                    <span>1 Year Warranty</span>
                </div>
                <div class="secure-item">
                    <i class="ph ph-medal"></i>
                    <span>Top Brand</span>
                </div>
            </div>

            <h3>About this item</h3>
            <ul class="features-list">
                <li><i class="ph-fill ph-caret-right"></i>
                    <%= product.description %>
                </li>
                <% if (product.traits && product.traits.length> 0) { %>
                    <% product.traits.forEach(trait=> { %>
                        <li><i class="ph-fill ph-caret-right"></i>
                            <%= trait %>
                        </li>
                        <% }); %>
                            <% } else { %>
                                <li><i class="ph-fill ph-caret-right"></i> Premium build quality and materials.</li>
                                <li><i class="ph-fill ph-caret-right"></i> 100% genuine and verified product.</li>
                                <li><i class="ph-fill ph-caret-right"></i> Imported exclusive collection.</li>
                                <% } %>
            </ul>

            <div style="display: flex; gap: 16px; flex-direction: column;">
                <a href="<%= user ? '/checkout?id=' + product.id : '/login' %>" class="btn-buy-lg">
                    <i class="ph-fill ph-lightning"></i>
                    <%= user ? 'Buy Now' : 'Login to Buy' %>
                </a>
                
                <% if (user) { %>
                    <form action="/cart/add" method="POST" style="margin: 0;">
                        <input type="hidden" name="productId" value="<%= product.id %>">
                        <button type="submit" class="btn-cart-lg" style="width: 100%;">
                            <i class="ph ph-shopping-cart"></i> Add to Cart
                        </button>
                    </form>
                <% } else { %>
                    <button class="btn-cart-lg" onclick="window.location.href='/login'">
                        <i class="ph ph-shopping-cart"></i> Login to Add
                    </button>
                <% } %>
            </div>

            <div
                style="margin-top: 24px; color: var(--text-muted); font-size: 0.9rem; display: flex; align-items: center; gap: 8px;">
                <i class="ph ph-lock-key" style="font-size: 1.2rem;"></i> Secure transaction via encrypted gateway.
            </div>

        </div>
    </div>

    <!-- Footer -->
    <footer
        style="background: rgba(0,0,0,0.5); border-top: 1px solid rgba(255,255,255,0.05); padding: 40px 24px; margin-top: 60px; text-align: center; color: var(--text-muted);">
        <p>Copyright &copy; <%= new Date().getFullYear() %> SamKart. All rights reserved.</p>
    </footer>

</body>

</html>