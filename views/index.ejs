            <div class="cat-card-name">Electronics</div>
            <div class="cat-card-count">1200+ items</div>
        </a>
        <a href="/explore?cat=Fashion" class="cat-card">
            <div class="cat-card-icon" style="background:#fff0f5;">👗</div>
            <div class="cat-card-name">Fashion</div>
            <div class="cat-card-count">800+ items</div>
        </a>
        <a href="/explore?cat=Appliances" class="cat-card">
            <div class="cat-card-icon" style="background:#f0fff4;">🧹</div>
