        </a>
        <a href="/explore?cat=Beauty" class="cat-card">
            <div class="cat-card-icon" style="background:#fff8e8;">💄</div>
            <div class="cat-card-name">Beauty</div>
            <div class="cat-card-count">600+ items</div>
        </a>
    </div>

    <!-- Today's Deals -->
    <div class="section-header">
        <div class="section-title">Today's Best Deals 🔥</div>
        <a href="/explore" class="section-see-all">See All Deals <i class="ph ph-arrow-right"></i></a>
    </div>

    <div class="product-grid">
        <% if (listings && listings.length > 0) { %>
            <% listings.forEach(function(product) { %>
                <%
                    let parsedPrice = parseFloat(product.price);
                    let finalPrice = parsedPrice < 1000 ? Math.floor(((parsedPrice * 7391) % 9000) + 1000) : parsedPrice;
                    let discount = Math.floor(Math.random() * 40 + 15);
                    let oldPrice = Math.floor(finalPrice * (100 / (100 - discount)));
                    let rating = (3.5 + Math.random() * 1.5).toFixed(1);
                    let reviews = Math.floor(Math.random() * 5000 + 50);
                %>
                <div class="ec-product-card" onclick="window.location.href='/asset-details?id=<%= product.id %>'">
                    <div class="badge-discount">-<%= discount %>%</div>
                    <div class="ec-product-img-wrap">
                        <img src="<%= product.image %>" class="ec-product-img" alt="<%= product.title %>">
                    </div>
                    <div class="ec-product-info">
                        <div class="ec-brand"><%= product.brand %></div>
                        <div class="ec-title" title="<%= product.title %>"><%= product.title %></div>
                        <div class="ec-rating">
                            <i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star"></i><i class="ph-fill ph-star-half"></i>
                            <span>(<%= reviews %>)</span>
                        </div>
                        <div class="ec-price-row">
                            <div class="ec-price"><sup>₹</sup><%= finalPrice.toLocaleString('en-IN') %></div>
                            <div class="ec-old-price">₹<%= oldPrice.toLocaleString('en-IN') %></div>
                        </div>
                        <div class="ec-save" style="margin-bottom:10px;">✓ Save ₹<%= (oldPrice - finalPrice).toLocaleString('en-IN') %></div>
                        <form action="/cart/add" method="POST" style="margin: 0;">
                            <input type="hidden" name="productId" value="<%= product.id %>">
                            <button type="submit" class="btn-cart" onclick="event.stopPropagation();">
                                <i class="ph ph-shopping-cart"></i> Add to Cart
                            </button>
                        </form>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div style="grid-column: 1 / -1; padding: 60px; text-align: center; color: #888; background: white; border-radius: 16px;">
                <div style="font-size: 3rem; margin-bottom: 12px;">📦</div>
                <p>No products available right now. Check back soon!</p>
            </div>
        <% } %>
    </div>

    <!-- Banner Cards -->
    <div class="banner-grid">
