            <!-- HOW IT WORKS -->
            <section>
                <div class="container">
                    <h2 style="font-size: 2.5rem; margin-bottom: 48px; text-align: center;">How It Works</h2>
                    <div class="grid-3">
                        <div class="step-card">
                            <div class="step-icon"><i class="ph ph-cart"></i></div>
                            <h3 style="margin-bottom: 16px;">Create an Account</h3>
                            <p class="text-muted">Once you’ve set up your cart of choice, connect it to NovaStock
                                by
                                clicking
                                the cart icon.</p>
                        </div>
                        <div class="step-card">
                            <div class="step-icon"><i class="ph ph-squares-four"></i></div>
                            <h3 style="margin-bottom: 16px;">Create collection</h3>
                            <p class="text-muted">Click My Collections and set up your collection. Add social links,
                                a
                                description, and profile images.</p>
                        </div>
                        <div class="step-card">
                            <div class="step-icon"><i class="ph ph-tag"></i></div>
                            <h3 style="margin-bottom: 16px;">Start Earning</h3>
                            <p class="text-muted">Choose between sales, fixed-price listings, and declining-price
                                listings.
                                You choose how you want to sell.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- CONTACT -->
            <section id="contact" style="background: linear-gradient(180deg, #0b0515 0%, #160a2b 100%);">
                <div class="container grid md:grid-cols-2 gap-12 items-center"
                    style="display: grid; grid-template-columns: 1fr 1fr; gap: 64px;">
                    <div>
                        <h2 style="font-size: 2.5rem; margin-bottom: 24px;">Get in Touch</h2>
                        <p class="text-muted" style="margin-bottom: 32px; font-size: 1.1rem; line-height: 1.6;">
                            Have questions? We'd love to hear from you. customized solutions regarding buying or
                            selling
                            Products.
                        </p>
                        <div class="flex flex-col gap-6">
                            <div class="flex items-center gap-4">
                                <div
                                    style="width: 48px; height: 48px; background: rgba(255,255,255,0.05); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 1.2rem;">
                                    <i class="ph-fill ph-envelope"></i>
                                </div>
                                <div>
                                    <div style="font-weight: 600;">Email Us</div>
                                    <div class="text-muted">contact@novamint.com</div>
                                </div>
                            </div>
                            <div class="flex items-center gap-4">
                                <div
                                    style="width: 48px; height: 48px; background: rgba(255,255,255,0.05); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 1.2rem;">
                                    <i class="ph-fill ph-phone"></i>
                                </div>
                                <div>
                                    <div style="font-weight: 600;">Call Us</div>
                                    <div class="text-muted">+91 7201866905</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="glass-card" style="padding: 40px;">
                        <form action="/contact" method="POST">
                            <div style="margin-bottom: 20px;">
                                <label
                                    style="display: block; margin-bottom: 8px; color: var(--text-muted); font-size: 0.9rem;">Your
                                    Name</label>
                                <input type="text" name="name" class="glass-input" placeholder="John Doe" required>
                            </div>
                            <div style="margin-bottom: 20px;">
                                <label
                                    style="display: block; margin-bottom: 8px; color: var(--text-muted); font-size: 0.9rem;">Email
                                    Address</label>
                                <input type="email" name="email" class="glass-input" placeholder="john@example.com"
                                    required>
                            </div>
                            <div style="margin-bottom: 24px;">
                                <label
                                    style="display: block; margin-bottom: 8px; color: var(--text-muted); font-size: 0.9rem;">Message</label>
                                <textarea name="message" class="glass-input" rows="4" placeholder="How can we help you?"
                                    style="height: auto; padding-top: 12px;" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary"
                                style="width: 100%; justify-content: center; height: 50px;">Send
                                Message</button>
                        </form>
                    </div>
                </div>
            </section>

            <!-- Footer -->
            <footer style="border-top: 1px solid var(--border-light); padding: 80px 0; background: #080310;">
                <div class="container grid-4" style="margin-bottom: 60px;">
                    <div>
                        <div class="flex items-center gap-2 mb-6">
                            <div
                                style="width: 32px; height: 32px; background: var(--primary); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 800;">
                                N</div>
                            <span style="font-weight: 700;">NovaStock</span>
                        </div>
                        <p class="text-muted text-sm" style="line-height: 1.6;">The best way to trade Products
                            confidently.
                            Join our
                            community today and start your journey.</p>
                    </div>
                    <div>
                        <h4 style="margin-bottom: 24px;">Marketplace</h4>
                        <div class="flex flex-col gap-3 text-sm text-muted">
                            <a href="/explore" class="nav-link">All Products</a>
                            <a href="/explore?category=Art" class="nav-link">Art</a>
                            <a href="/explore?category=Music" class="nav-link">Music</a>
                            <a href="/explore?category=Virtual+Worlds" class="nav-link">Virtual Worlds</a>
                        </div>
                    </div>
                    <div>
                        <h4 style="margin-bottom: 24px;">My Account</h4>
                        <div class="flex flex-col gap-3 text-sm text-muted">
                            <a href="/profile" class="nav-link">Profile</a>
                            <a href="/profile#favorites" class="nav-link">Favorites</a>
                            <a href="/profile#collections" class="nav-link">My Collections</a>
                            <a href="/profile#settings" class="nav-link">Settings</a>
                        </div>
                    </div>
                    <div>
                        <h4 style="margin-bottom: 24px;">Newsletter</h4>
                        <p class="text-muted text-sm mb-4">Subscribe for the latest updates.</p>
                        <div class="flex gap-2">
                            <input type="email" class="glass-input" placeholder="Your email" style="height: 48px;">
                            <button class="btn btn-primary" style="height: 48px;"><i
                                    class="ph ph-arrow-right"></i></button>
                        </div>
                    </div>
                </div>
                <div class="container">
                    <div class="text-center text-muted text-sm"
                        style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 32px;">
                        <%= (content && content.footer && content.footer.text) ? content.footer.text
                            : '© 2026 NovaStock. All rights reserved.' %>
                    </div>
                </div>
            </footer>
            </footer>

</body>

</html>