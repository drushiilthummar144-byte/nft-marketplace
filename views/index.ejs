<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium Store | Discover Premium Products & Electronics</title>
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/glass.css">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <style>
        html {
            scroll-behavior: smooth;
        }

        /* Section Styles */
        section {
            padding: 100px 0;
            position: relative;
        }

        /* Grid Layouts */
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
        }

        .grid-4 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
        }

        /* Collection Card */
        .collection-card {
            position: relative;
            overflow: hidden;
            border-radius: 16px;
            transition: transform 0.3s ease;
        }

        .collection-card:hover {
            transform: translateY(-8px);
        }

        .collection-img {
            height: 260px;
            background: #2A1A40;
            background-size: cover;
            background-position: center;
        }

        .collection-info {
            padding: 20px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-top: none;
            border-radius: 0 0 16px 16px;
        }

        /* Brand Card */
        .brand-card {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: 0.2s;
        }

        .brand-card:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        .brand-rank {
            font-weight: 800;
            color: var(--text-muted);
            width: 24px;
        }

        .brand-avatar {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #333;
        }

        /* Step Card */
        .step-card {
            text-align: center;
            padding: 40px 24px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .step-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, rgba(127, 48, 255, 0.2), rgba(48, 133, 255, 0.2));
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 2rem;
            color: #fff;
        }

        @media (max-width: 1024px) {

            .grid-3,
            .grid-4 {
                grid-template-columns: repeat(2, 1fr);
            }

            .hero-grid-responsive {
                grid-template-columns: 1fr !important;
                gap: 32px !important;
                text-align: center;
            }

            .hero-product-card {
                margin: 0 auto;
            }

            .hero-title {
                font-size: 3.5rem !important;
            }
        }

        @media (max-width: 768px) {

            .grid-3,
            .grid-4 {
                grid-template-columns: 1fr;
            }

            .hero-title {
                font-size: 2.8rem !important;
            }

            .hero-buttons-mobile {
                flex-direction: column;
                width: 100%;
            }

            .hero-buttons-mobile a {
                width: 100%;
            }

            .stats-mobile-center {
                justify-content: center;
            }
        }

        @keyframes float {
            0% {
                transform: translateY(0px) rotateY(-10deg) rotateX(5deg);
            }

            50% {
                transform: translateY(-20px) rotateY(-5deg) rotateX(5deg);
            }

            100% {
                transform: translateY(0px) rotateY(-10deg) rotateX(5deg);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes glow {
            0% {
                box-shadow: 0 0 5px rgba(127, 48, 255, 0.2);
            }

            50% {
                box-shadow: 0 0 20px rgba(127, 48, 255, 0.6);
            }

            100% {
                box-shadow: 0 0 5px rgba(127, 48, 255, 0.2);
            }
        }

        .animate-float {
            animation: float 6s ease-in-out infinite;
        }

        .animate-fade-up {
            opacity: 0;
            animation: fadeInUp 0.8s ease-out forwards;
        }

        .delay-100 {
            animation-delay: 0.1s;
        }

        .delay-200 {
            animation-delay: 0.2s;
        }

        .delay-300 {
            animation-delay: 0.3s;
        }

        .seller-card:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.08);
            border-color: var(--primary);
        }

        .verified-badge {
            color: #3085FF;
            margin-left: 4px;
        }
    </style>
</head>

