<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NovaMint | Complete Payment</title>
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/glass.css">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <style>
        body {
            background-color: #0b0515;
            padding-top: 100px;
            min-height: 100vh;
            color: white;
            background-image: radial-gradient(circle at top right, rgba(127, 48, 255, 0.1) 0%, transparent 40%),
                radial-gradient(circle at bottom left, rgba(48, 133, 255, 0.1) 0%, transparent 40%);
        }

        .payment-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(20px);
            margin: 0 auto;
            max-width: 550px;
            position: relative;
            overflow: hidden;
        }

        .payment-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #00ff9d, #00b8ff);
        }

        .payment-method {
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 20px;
            border-radius: 16px;
            margin-bottom: 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .payment-method:hover {
            border-color: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }

        .payment-method.active {
            background: rgba(0, 255, 157, 0.05);
            border-color: #00ff9d;
            box-shadow: 0 0 20px rgba(0, 255, 157, 0.2);
        }

        .payment-method.active::before {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 0;
            width: 4px;
            background: #00ff9d;
        }

        .method-icon {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            font-size: 1.8rem;
        }

        .crypto-icon {
            background: rgba(127, 48, 255, 0.1);
            color: #7828C8;
        }

        .card-icon {
            background: rgba(255, 255, 255, 0.05);
            color: white;
        }

        .payment-method.active .crypto-icon {
            background: rgba(0, 255, 157, 0.1);
            color: #00ff9d;
        }

        .btn-confirm {
            background: linear-gradient(135deg, #00ff9d, #00b8ff);
            height: 64px;
            border-radius: 16px;
            font-size: 1.25rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            border: none;
            color: #0b0515;
            width: 100%;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 20px rgba(0, 255, 157, 0.3);
            margin-top: 32px;
        }

        .btn-confirm:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(0, 255, 157, 0.5);
        }
    </style>
</head>

<body>
    <nav class="glass-nav"
        style="position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 20px 0; border-bottom: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(20px); background: rgba(11, 5, 21, 0.85);">
        <div class="container flex justify-between items-center">
            <div class="flex items-center gap-4">
                <a href="/checkout?id=<%= nft.id %>"
                    style="color: rgba(255,255,255,0.6); font-size: 1.5rem; text-decoration: none; display: flex; align-items: center; transition: 0.2s;"><i
                        class="ph ph-arrow-left hover:text-white"></i></a>
                <div style="width: 1px; height: 24px; background: rgba(255,255,255,0.1);"></div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <% if (content && content.visuals && content.visuals.logoImage) { %>
                        <img src="<%= content.visuals.logoImage %>" alt="Site Logo"
                            style="height: 36px; width: auto; object-fit: contain;">
                        <% } else { %>
                            <div
                                style="width: 36px; height: 36px; background: linear-gradient(135deg, var(--primary), #FF3085); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1rem; box-shadow: 0 0 15px rgba(127, 48, 255, 0.5);">
                                N</div>
                            <a href="/"
                                style="font-size: 1.3rem; font-weight: 800; color: white; text-decoration: none; letter-spacing: -0.5px;">
                                <%= (content && content.visuals && content.visuals.logoText) ? content.visuals.logoText
                                    : 'NovaMint' %>
                            </a>
                            <% } %>
                </div>
            </div>
        </div>
    </nav>

    <div class="container" style="padding-top: 40px; padding-bottom: 80px;">
        <div class="payment-card">

            <div style="text-align: center; margin-bottom: 40px;">
                <div
                    style="width: 64px; height: 64px; background: rgba(0,255,157,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; border: 1px solid rgba(0,255,157,0.3);">
                    <i class="ph-fill ph-wallet" style="font-size: 2rem; color: #00ff9d;"></i>
                </div>
                <h1 style="font-size: 2.2rem; margin-bottom: 8px;">Complete Payment</h1>
                <p style="color: rgba(255,255,255,0.5); font-size: 1.1rem;">Choose how you want to pay for <strong>
                        <%= nft.title %>
                    </strong>.</p>
            </div>

            <div class="payment-method active">
                <div class="method-icon crypto-icon">
                    <i class="ph-fill ph-currency-eth"></i>
                </div>
                <div style="flex: 1;">
                    <div style="font-weight: 700; font-size: 1.1rem; margin-bottom: 4px;">Crypto Wallet</div>
                    <div style="color: rgba(255,255,255,0.5); font-size: 0.9rem;">Pay via MetaMask, Phantom,
                        ConnectWallet</div>
                </div>
                <i class="ph-fill ph-check-circle" style="font-size: 1.5rem; color: #00ff9d;"></i>
            </div>

            <div class="payment-method">
                <div class="method-icon card-icon">
                    <i class="ph-fill ph-credit-card"></i>
                </div>
                <div style="flex: 1;">
                    <div style="font-weight: 700; font-size: 1.1rem; margin-bottom: 4px;">Credit / Debit Card</div>
                    <div style="color: rgba(255,255,255,0.5); font-size: 0.9rem;">Powered by MoonPay</div>
                </div>
                <div
                    style="background: rgba(255,255,255,0.1); padding: 4px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">
                    Visa / MC</div>
            </div>

            <div class="payment-method">
                <div class="method-icon" style="background: rgba(255, 153, 0, 0.1); color: #ff9900;">
                    <i class="ph-fill ph-package"></i>
                </div>
                <div style="flex: 1;">
                    <div style="font-weight: 700; font-size: 1.1rem; margin-bottom: 4px;">Cash on Delivery</div>
                    <div style="color: rgba(255,255,255,0.5); font-size: 0.9rem;">Pay with physical cash/crypto at
                        doorstep</div>
                </div>
                <div
                    style="background: rgba(255, 153, 0, 0.1); color: #ff9900; padding: 4px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase;">
                    Physical</div>
            </div>

            <div style="text-align: center; margin-top: 32px; font-size: 1.5rem; font-weight: 800; color: white;">
                Total Due: <span style="color: #00ff9d;">
                    <%= (parseFloat(nft.price) * 1.025).toFixed(4) %> ETH
                </span>
            </div>

            <form action="/payment/confirm" method="POST" id="paymentForm">
                <input type="hidden" name="id" value="<%= nft.id %>">
                <button type="submit" class="btn-confirm" onclick="return confirmPayment(event)">
                    Confirm & Complete <i class="ph-bold ph-check"></i>
                </button>
            </form>

            <div
                style="text-align: center; margin-top: 24px; color: rgba(255,255,255,0.4); font-size: 0.85rem; display: flex; align-items: center; justify-content: center; gap: 8px;">
                <i class="ph-fill ph-shield-check"></i> 100% Secured and Encrypted by Blockchain
            </div>
        </div>
    </div>

    <script>
        function confirmPayment(event) {
            event.preventDefault(); // Prevent form from submitting instantly

            const btn = document.querySelector('.btn-confirm');
            btn.innerHTML = '<i class="ph ph-spinner ph-spin"></i> Processing...';
            btn.style.opacity = '0.7';
            btn.style.pointerEvents = 'none';

            // Simulate processing time
            setTimeout(() => {
                btn.innerHTML = '<i class="ph-bold ph-check-circle"></i> Success!';
                btn.style.background = '#00ff9d';
                btn.style.color = '#0b0515';

                // Submit form after success animation
                setTimeout(() => {
                    document.getElementById('paymentForm').submit();
                }, 800);
            }, 1500);

            return false;
        }

        // Add visual click effect to payment method cards
        document.querySelectorAll('.payment-method').forEach(method => {
            method.addEventListener('click', function () {
                document.querySelectorAll('.payment-method').forEach(m => {
                    m.classList.remove('active');
                    const check = m.querySelector('.ph-check-circle');
                    if (check) check.remove();
                    m.querySelector('.method-icon').classList.remove('crypto-icon');
                    m.querySelector('.method-icon').classList.add('card-icon');
                });

                this.classList.add('active');
                this.querySelector('.method-icon').classList.add('crypto-icon');
                this.querySelector('.method-icon').classList.remove('card-icon');

                if (!this.querySelector('.ph-check-circle')) {
                    const checkIcon = document.createElement('i');
                    checkIcon.className = 'ph-fill ph-check-circle';
                    checkIcon.style.fontSize = '1.5rem';
                    checkIcon.style.color = '#00ff9d';
                    this.appendChild(checkIcon);
                }
            });
        });
    </script>
</body>

</html>