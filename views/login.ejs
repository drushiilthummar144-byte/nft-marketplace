<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SamKart | Sign In</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            position: relative;
            overflow: hidden;
        }

        body::before {
            content: '';
            position: absolute;
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(120,40,200,0.2), transparent 70%);
            top: -200px; right: -100px;
            animation: float 8s ease-in-out infinite;
        }

        body::after {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(247,151,30,0.15), transparent 70%);
            bottom: -100px; left: -100px;
            animation: float 6s ease-in-out infinite reverse;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-30px); }
        }

        .login-wrapper {
            width: 100%;
            max-width: 460px;
            position: relative;
            z-index: 10;
        }

        /* LOGO */
        .login-logo {
            text-align: center;
            margin-bottom: 32px;
        }

        .login-logo-icon {
            width: 56px; height: 56px;
            background: linear-gradient(135deg, #f7971e, #ffd200);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            font-weight: 900;
            color: #1a1a2e;
            margin-bottom: 12px;
            box-shadow: 0 8px 24px rgba(247,151,30,0.4);
        }

        .login-logo-name {
            display: block;
            font-size: 2rem;
            font-weight: 900;
            color: white;
            letter-spacing: -1px;
        }

        .login-logo-sub {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.4);
        }

        /* CARD */
        .login-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 24px;
            padding: 36px;
            backdrop-filter: blur(20px);
            box-shadow: 0 32px 80px rgba(0,0,0,0.5);
        }

        /* TOGGLE TABS */
        .tab-switcher {
            display: flex;
            background: rgba(0,0,0,0.3);
            border-radius: 14px;
            padding: 4px;
            margin-bottom: 32px;
            gap: 4px;
        }

        .tab-btn {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background: transparent;
            color: rgba(255,255,255,0.4);
            font-family: 'Inter', sans-serif;
        }

        .tab-btn.active-customer {
            background: linear-gradient(135deg, #1a1a2e, #0f3460);
            color: white;
            box-shadow: 0 4px 16px rgba(15,52,96,0.5);
        }

        .tab-btn.active-admin {
            background: linear-gradient(135deg, #7828C8, #FF3085);
            color: white;
            box-shadow: 0 4px 16px rgba(120,40,200,0.5);
        }

        /* FORMS */
        .form-panel { display: none; }
        .form-panel.visible { display: block; }

        .form-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: white;
            margin-bottom: 6px;
        }

        .form-sub {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.45);
            margin-bottom: 24px;
        }

        .input-label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: rgba(255,255,255,0.6);
            margin-bottom: 8px;
            letter-spacing: 0.3px;
        }

        .input-field {
            width: 100%;
            padding: 14px 18px;
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            color: white;
            font-size: 0.95rem;
            font-family: 'Inter', sans-serif;
            outline: none;
            margin-bottom: 18px;
            transition: all 0.2s;
        }

        .input-field:focus {
            border-color: rgba(247,151,30,0.5);
            box-shadow: 0 0 16px rgba(247,151,30,0.15);
            background: rgba(0,0,0,0.5);
        }

        .input-field::placeholder { color: rgba(255,255,255,0.25); }

        .btn-customer {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #1a1a2e, #0f3460);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 6px 20px rgba(15,52,96,0.4);
            margin-top: 4px;
        }

        .btn-customer:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(15,52,96,0.6);
        }

        .btn-admin {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #7828C8, #FF3085);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 6px 20px rgba(120,40,200,0.4);
            margin-top: 4px;
        }

        .btn-admin:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(120,40,200,0.6);
        }

        /* Error/Info */
        .alert-error {
            background: rgba(255,70,70,0.1);
            border: 1px solid rgba(255,70,70,0.3);
            color: #ff6b6b;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 0.85rem;
            margin-bottom: 18px;
        }

        .admin-hint {
            background: rgba(120,40,200,0.1);
            border: 1px solid rgba(120,40,200,0.3);
            color: rgba(255,255,255,0.7);
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 0.82rem;
            margin-bottom: 18px;
            line-height: 1.6;
        }

        .admin-hint strong { color: #ffd200; }

        .divider {
            text-align: center;
            color: rgba(255,255,255,0.25);
            font-size: 0.78rem;
            margin: 20px 0;
            position: relative;
        }

        .divider::before, .divider::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 40%;
            height: 1px;
            background: rgba(255,255,255,0.08);
        }

        .divider::before { left: 0; }
        .divider::after { right: 0; }

        .register-link {
            text-align: center;
            color: rgba(255,255,255,0.4);
            font-size: 0.85rem;
            margin-top: 20px;
        }

        .register-link a {
            color: #ffd200;
            text-decoration: none;
            font-weight: 700;
        }

        .back-home {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            color: rgba(255,255,255,0.35);
            text-decoration: none;
            font-size: 0.82rem;
            margin-top: 24px;
            transition: color 0.2s;
        }

        .back-home:hover { color: rgba(255,255,255,0.7); }
    </style>
</head>
<body>

    <div class="login-wrapper">

        <!-- LOGO -->
        <div class="login-logo">
            <div class="login-logo-icon">S</div>
            <span class="login-logo-name">SamKart</span>
            <div class="login-logo-sub">Welcome back! Please sign in.</div>
        </div>

        <!-- CARD -->
        <div class="login-card">

            <!-- TAB SWITCHER -->
            <div class="tab-switcher">
                <button class="tab-btn active-customer" id="tabCustomer" onclick="switchTab('customer')">
                    🛍️ Customer Login
                </button>
                <button class="tab-btn" id="tabAdmin" onclick="switchTab('admin')">
                    👑 Admin Login
                </button>
            </div>

            <!-- CUSTOMER FORM -->
            <div class="form-panel visible" id="panelCustomer">
                <div class="form-title">Customer Sign In</div>
                <div class="form-sub">Login to track your orders and shopping cart.</div>

                <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert-error">⚠️ <%= error %></div>
                <% } %>

                <form action="/login" method="POST">
                    <label class="input-label">Email Address</label>
                    <input type="email" name="email" class="input-field" placeholder="you@example.com" required>

                    <label class="input-label">Password</label>
                    <input type="password" name="password" class="input-field" placeholder="Enter your password" required>

                    <button type="submit" class="btn-customer">
                        🛒 Sign In to Shop
                    </button>
                </form>

                <div class="register-link" style="margin-top: 20px;">
                    New to SamKart? <a href="/register">Create Account</a>
                </div>
            </div>

            <!-- ADMIN FORM -->
            <div class="form-panel" id="panelAdmin">
                <div class="form-title">Admin / CEO Panel</div>
                <div class="form-sub">Restricted access — Authorized personnel only.</div>

                <form action="/admin/login" method="POST">
                    <label class="input-label">Admin Email</label>
                    <input type="email" name="email" class="input-field" placeholder="admin@samkart.com" required>

                    <label class="input-label">Admin Password</label>
                    <input type="password" name="password" class="input-field" placeholder="Enter admin password" required>

                    <button type="submit" class="btn-admin">
                        👑 Access CEO Dashboard
                    </button>
                </form>
            </div>

        </div>

        <a href="/" class="back-home">← Back to Homepage</a>

    </div>

<script>
function switchTab(tab) {
    const tabCustomer = document.getElementById('tabCustomer');
    const tabAdmin    = document.getElementById('tabAdmin');
    const panelCustomer = document.getElementById('panelCustomer');
    const panelAdmin    = document.getElementById('panelAdmin');

    if (tab === 'customer') {
        tabCustomer.className = 'tab-btn active-customer';
        tabAdmin.className    = 'tab-btn';
        panelCustomer.classList.add('visible');
        panelAdmin.classList.remove('visible');
    } else {
        tabAdmin.className    = 'tab-btn active-admin';
        tabCustomer.className = 'tab-btn';
        panelAdmin.classList.add('visible');
        panelCustomer.classList.remove('visible');
    }
}
</script>

</body>
</html>