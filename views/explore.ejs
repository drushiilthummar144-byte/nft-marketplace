<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium Store | Explore</title>
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/glass.css">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <style>
        .grid-layout {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
            padding: 40px 0;
        }

        .product-card {
            transition: transform 0.2s;
        }

        .product-card:hover {
            transform: translateY(-5px);
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#7F30FF">
    <link rel="apple-touch-icon" href="https://ui-avatars.com/api/?name=NovaStock&background=7F30FF&color=fff&size=192">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').then(registration => {
                    console.log('ServiceWorker registration successful');
                }).catch(err => {
                    console.log('ServiceWorker registration failed: ', err);
                });
            });
        }
    </script>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="glass-nav"
        style="position: sticky; top: 0; z-index: 100; padding: 20px 0; border-bottom: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(20px); background: rgba(11, 5, 21, 0.8);">
        <div class="container flex justify-between items-center">
            <div class="flex items-center gap-2">
                <% if (content && content.visuals && content.visuals.logoImage) { %>
                    <img src="<%= content.visuals.logoImage %>" alt="Site Logo"
                        style="height: 48px; width: auto; max-width: 150px; object-fit: contain;">
                    <% } else { %>
                        <div
                            style="width: 40px; height: 40px; background: var(--primary); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem;">
                            N</div>
                        <a href="/" style="font-size: 1.2rem; font-weight: 700; color: white; text-decoration: none;">
                            <%= (content && content.visuals && content.visuals.logoText) ? content.visuals.logoText
                                : 'NovaStock' %>
                        </a>
                        <% } %>
            </div>
            <div class="hidden md:flex gap-10">
                <a href="/" class="nav-link">Home</a>
                <a href="/explore" class="nav-link active" style="color: white;">Explore</a>
                <a href="/#sellers" class="nav-link">Brands</a>
                <a href="/#contact" class="nav-link">Contact</a>
            </div>
            <div class="flex items-center gap-4">
                <a href="/login" class="btn btn-primary" style="padding: 10px 24px;">Login</a>
            </div>
        </div>
    </nav>

    <div class="container" style="padding-top: 40px;">
        <div class="flex justify-between items-end mb-10 wrap-mobile" style="gap: 24px; margin-bottom: 40px;">
            <div>
                <h1
                    style="font-size: 2.5rem; margin-bottom: 12px; background: linear-gradient(to right, #fff, #a1a1aa); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">
                    Explore Collections</h1>
                <p class="text-muted">Browse the best exclusive Products from top brands.</p>
            </div>

            <div class="glass-card"
                style="padding: 8px; display: flex; gap: 12px; align-items: center; border-radius: 50px;">
                <div style="position: relative;">
                    <i class="ph ph-magnifying-glass"
                        style="position: absolute; left: 16px; top: 12px; color: var(--text-muted);"></i>
                    <input type="text" id="searchInput" class="glass-input" placeholder="Search items..."
                        style="padding-left: 44px; border: none; background: transparent; width: 200px; height: 40px;">
                </div>
            </div>
        </div>

        <!-- Sorting & Filtering -->
        <div class="flex justify-between items-center mb-8 wrap-mobile" style="gap: 16px;">
            <!-- Filter Pills -->
            <div class="flex gap-3 overflow-x-auto" style="padding-bottom: 8px; flex: 1; -webkit-overflow-scrolling: touch;">
                <button class="filter-pill active" data-category="all" onclick="filterItems('all')">All Items</button>
                <button class="filter-pill" data-category="Mobiles" onclick="filterItems('Mobiles')">Mobiles</button>
                <button class="filter-pill" data-category="Electronics" onclick="filterItems('Electronics')">Electronics</button>
                <button class="filter-pill" data-category="Fashion" onclick="filterItems('Fashion')">Fashion</button>
                <button class="filter-pill" data-category="Home" onclick="filterItems('Home')">Home &amp; Decor</button>
                <button class="filter-pill" data-category="Sports" onclick="filterItems('Sports')">Sports</button>
            </div>

            <!-- Sort Dropdown -->
            <div class="glass-card" style="padding: 4px 12px; border-radius: 50px; display: flex; align-items: center; gap: 8px; min-width: max-content;">
                <span class="text-sm text-muted">Sort by:</span>
                <select id="sortSelect" class="glass-input text-sm" style="border: none; background: transparent; color: white; outline: none; padding: 4px 0;">
                    <option value="featured" style="background: #0b0515; color: white;">Featured</option>
                    <option value="price-low" style="background: #0b0515; color: white;">Price: Low to High</option>
                    <option value="price-high" style="background: #0b0515; color: white;">Price: High to Low</option>
                </select>
            </div>
        </div>

        <div class="grid-layout" id="productGrid">
            <% if (listings && listings.length> 0) { %>
                <% listings.forEach(function(product) { 
                    // Calculate consistent display price
                    const displayPrice = parseFloat(product.price) < 1000 ? Math.floor(((parseFloat(product.price) * 7391) % 9000) + 1000) : parseFloat(product.price);
                %>
                    <div class="glass-card product-card" style="padding: 12px;"
                        data-title="<%= (product.title || '').toLowerCase() %>"
                        data-brand="<%= (product.brand || '').toLowerCase() %>"
                        data-category="<%= (product.category || 'Electronics') %>"
                        data-price="<%= displayPrice %>">
                        <div
                            style="height: 240px; border-radius: 12px; background: center/cover url('<%= product.image %>'); margin-bottom: 16px; position: relative;">
                            <div
                                style="position: absolute; top: 12px; right: 12px; background: rgba(0,0,0,0.6); color: white; padding: 4px 8px; border-radius: 20px; font-size: 0.75rem; backdrop-filter: blur(4px);">
                                <%= product.category || 'Mobiles' %>
                            </div>
                        </div>
                        <div style="padding: 0 4px;">
                            <div class="flex justify-between items-start mb-2">
                                <h3
                                    style="font-size: 1.1rem; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%;">
                                    <%= product.title %>
                                </h3>
                                <div class="status-dot <%= product.status === 'Active' ? 'active' : '' %>"
                                    title="<%= product.status %>"></div>
                            </div>
                            <div class="text-muted text-sm mb-4">by <%= product.brand %>
                            </div>

                            <div class="flex justify-between items-center border-t border-white-10 pt-4">
                                <div>
                                    <div class="text-xs text-muted">Price</div>
                                    ₹<%= displayPrice.toLocaleString('en-IN') %>%>
                                </div>
                                <a href="<%= user ? '/asset-details?id=' + product.id : '/login' %>"
                                    class="btn btn-secondary"
                                    style="font-size: 0.85rem; padding: 6px 12px; text-decoration: none;">
                                    <%= user ? 'Buy Now' : 'Login to Buy' %>
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                        <div
                            style="grid-column: 1 / -1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 100px 20px; background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.1); border-radius: 20px; text-align: center;">
                            <i class="ph-fill ph-package"
                                style="font-size: 4rem; color: var(--primary); margin-bottom: 24px; filter: drop-shadow(0 0 20px rgba(127,48,255,0.5));"></i>
                            <h2 style="font-size: 2rem; margin-bottom: 12px;">No Products Found</h2>
                            <p class="text-muted" style="max-width: 400px; margin-bottom: 32px; font-size: 1.1rem;">
                                There are currently no products available in the marketplace.</p>
                        </div>
                        <% } %>
        </div>

        <!-- Empty State -->
        <div id="emptyState" style="display: none; text-align: center; padding: 60px 0; color: var(--text-muted);">
            <i class="ph ph-magnifying-glass" style="font-size: 3rem; opacity: 0.5; margin-bottom: 16px;"></i>
            <p>No items found matching your criteria.</p>
        </div>
    </div>

    <style>
        .filter-pill {
            padding: 8px 16px;
            border-radius: 50px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(255, 255, 255, 0.02);
            color: var(--text-muted);
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .filter-pill:hover {
            border-color: var(--primary);
            color: white;
            background: rgba(127, 48, 255, 0.1);
        }

        .filter-pill.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #a1a1aa;
        }

        .status-dot.active {
            background: #00ff9d;
            box-shadow: 0 0 10px rgba(0, 255, 157, 0.5);
        }

        /* Mobile Wrap adjustment */
        @media (max-width: 768px) {
            .wrap-mobile {
                flex-direction: column;
                align-items: flex-start;
            }

            .wrap-mobile>div:last-child {
                width: 100%;
            }

            #searchInput {
                width: 100% !important;
            }
        }
    </style>

    <script>
        const searchInput = document.getElementById('searchInput');
        const cards = document.querySelectorAll('.product-card');
        const emptyState = document.getElementById('emptyState');
        const pills = document.querySelectorAll('.filter-pill');
        const sortSelect = document.getElementById('sortSelect');
        const productGrid = document.getElementById('productGrid');

        let currentCategory = 'all';
        let currentSearch = '';
        let currentSort = 'featured';

        // Check for category in URL
        const urlParams = new URLSearchParams(window.location.search);
        const catParam = urlParams.get('cat');
        if (catParam) {
            currentCategory = catParam;
            // Update pills
            pills.forEach(pill => {
                if (pill.dataset.category === catParam) {
                    pill.classList.add('active');
                } else {
                    pill.classList.remove('active');
                }
            });
        }

        // Search Listener
        searchInput.addEventListener('input', (e) => {
            currentSearch = e.target.value.toLowerCase();
            applyFilters();
        });

        // Filter Function
        function filterItems(category) {
            currentCategory = category;

            // Update active state of pills
            pills.forEach(pill => {
                if (pill.dataset.category === category) {
                    pill.classList.add('active');
                } else {
                    pill.classList.remove('active');
                }
            });

            applyFilters();
        }

        // Sort Listener
        sortSelect.addEventListener('change', (e) => {
            currentSort = e.target.value;
            applyFilters();
        });

        function applyFilters() {
            let visibleCount = 0;
            const visibleCards = [];

            cards.forEach(card => {
                const title = card.dataset.title;
                const brand = card.dataset.brand;
                const cardCategory = card.dataset.category;

                const matchesSearch = title.includes(currentSearch) || brand.includes(currentSearch);
                const matchesCategory = currentCategory === 'all' || cardCategory === currentCategory;

                if (matchesSearch && matchesCategory) {
                    card.style.display = 'block';
                    visibleCount++;
                    // Add subtle animation for appearance
                    card.style.animation = 'fadeIn 0.3s ease forwards';
                    visibleCards.push(card);
                } else {
                    card.style.display = 'none';
                }
            });

            // Apply sort logic
            if (currentSort !== 'featured') {
                visibleCards.sort((a, b) => {
                    const priceA = parseFloat(a.dataset.price);
                    const priceB = parseFloat(b.dataset.price);
                    if (currentSort === 'price-low') return priceA - priceB;
                    if (currentSort === 'price-high') return priceB - priceA;
                    return 0;
                });

                // Re-append to grid logic here
                // Note: to prevent removing standard layout items (like empty state or other grid contents),
                // we only append the visible items in sorted order
                visibleCards.forEach(card => productGrid.appendChild(card));
            }

            // Show/Hide Empty State
            emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
        }

        // Initial Filter Apply
        applyFilters();
    </script>

</body>

</html>